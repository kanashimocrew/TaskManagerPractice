<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaskManager.Views.TaskEditPage"
             Title="{Binding PageTitle}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">


            <StackLayout>
                <Label Text="Название задачи *"
                       FontSize="16"
                       FontAttributes="Bold"/>

                <Entry Text="{Binding Title}"
                       Placeholder="Введите название задачи"
                       FontSize="16"/>
            </StackLayout>


            <StackLayout>
                <Label Text="Описание"
                       FontSize="16"
                       FontAttributes="Bold"/>

                <Editor Text="{Binding Description}"
                        Placeholder="Введите описание задачи"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="80"
                        FontSize="16"/>
            </StackLayout>


            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <StackLayout Grid.Column="0">
                    <Label Text="Дата выполнения"
                           FontSize="16"
                           FontAttributes="Bold"/>

                    <DatePicker Date="{Binding DueDate}"
                                FontSize="16"/>
                </StackLayout>

                <StackLayout Grid.Column="1">
                    <Label Text="Время выполнения"
                           FontSize="16"
                           FontAttributes="Bold"/>

                    <TimePicker Time="{Binding DueTime}"
                                Format="HH:mm"
                                FontSize="16"/>
                </StackLayout>
            </Grid>

            <StackLayout>
                <Label Text="Приоритет"
                       FontSize="16"
                       FontAttributes="Bold"/>

                <Picker Title="Выберите приоритет"
                        ItemsSource="{Binding PriorityOptions}"
                        SelectedIndex="{Binding SelectedPriorityIndex}"
                        FontSize="16"/>
            </StackLayout>


            <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,30,0,0">
                <Button Grid.Column="0"
                        Text="Отмена"
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="LightGray"
                        TextColor="Black"/>

                <Button Grid.Column="1"
                        Text="{Binding SaveButtonText}"
                        Command="{Binding SaveTaskCommand}"
                        BackgroundColor="#512DA8"
                        TextColor="White"/>
            </Grid>

        </StackLayout>
    </ScrollView>

</ContentPage>