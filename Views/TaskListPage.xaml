<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:TaskManager.Converters"
             x:Class="TaskManager.Views.TaskListPage"
             Title="Задачи">

    <ContentPage.Resources>
        <converters:PriorityToColorConverter x:Key="PriorityToColor" />
        <converters:StatusToIconConverter x:Key="StatusToIcon" />
        <converters:DateTimeToStringConverter x:Key="DateTimeToString" />

        <Style x:Key="TaskCardStyle" TargetType="Frame">
            <Setter Property="Padding" Value="15" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HasShadow" Value="True" />
            <Setter Property="Margin" Value="10,5" />
        </Style>

        <Style x:Key="TitleLabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <Grid>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          Color="{StaticResource PrimaryColor}"
                          HeightRequest="50"
                          WidthRequest="50"/>


        <Grid IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">


            <Label Text="Задач еще нет"
                   IsVisible="{Binding HasTasks, Converter={StaticResource InverseBoolConverter}}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="18"
                   TextColor="Gray"
                   Margin="20"/>


            <RefreshView IsRefreshing="{Binding IsLoading}"
                        Command="{Binding LoadTasksCommand}">

                <CollectionView ItemsSource="{Binding Tasks}"
                              SelectionMode="None">

                    <CollectionView.EmptyView>
                        <Label Text="Задач еще нет"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="18"
                               TextColor="Gray"/>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>

                            <SwipeView>


                                <SwipeView.LeftItems>
                                    <SwipeItem Text="Статус"
                                              BackgroundColor="Orange"
                                              Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeStatusCommand}"
                                              CommandParameter="{Binding .}">
                                        <SwipeItem.IconImageSource>
                                            <FontImageSource Glyph="⚙️"
                                                           Color="White"
                                                           FontFamily="MaterialDesignIcons"
                                                           Size="20"/>
                                        </SwipeItem.IconImageSource>
                                    </SwipeItem>
                                </SwipeView.LeftItems>


                                <SwipeView.RightItems>
                                    <SwipeItem Text="Удалить"
                                              BackgroundColor="Red"
                                              Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                                              CommandParameter="{Binding .}">
                                        <SwipeItem.IconImageSource>
                                            <FontImageSource Glyph="🗑️"
                                                           Color="White"
                                                           FontFamily="MaterialDesignIcons"
                                                           Size="20"/>
                                        </SwipeItem.IconImageSource>
                                    </SwipeItem>
                                </SwipeView.RightItems>


                                <Frame Style="{StaticResource TaskCardStyle}"
                                       BackgroundColor="{Binding Priority, Converter={StaticResource PriorityToColor}}">

                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.NavigateToTaskDetailCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto, *, Auto"
                                          RowDefinitions="Auto, Auto">


                                        <Label Grid.Column="0"
                                               Grid.RowSpan="2"
                                               Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                               FontSize="24"
                                               VerticalOptions="Center"
                                               Margin="0,0,10,0"/>


                                        <Label Grid.Column="1"
                                               Grid.Row="0"
                                               Text="{Binding Title}"
                                               Style="{StaticResource TitleLabelStyle}"
                                               LineBreakMode="TailTruncation"/>

                                        <Label Grid.Column="1"
                                               Grid.Row="1"
                                               Text="{Binding DueDate, Converter={StaticResource DateTimeToString}}"
                                               FontSize="14"
                                               TextColor="Gray"
                                               Margin="0,5,0,0"/>

                                        <Label Grid.Column="2"
                                               Grid.RowSpan="2"
                                               Text="{Binding Priority}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="DarkGray"
                                               VerticalOptions="Center"/>

                                    </Grid>

                                </Frame>

                            </SwipeView>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </RefreshView>

        </Grid>


        <Button Text="+"
                Command="{Binding NavigateToCreateTaskCommand}"
                FontSize="24"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                BackgroundColor="{StaticResource PrimaryColor}"
                TextColor="White"/>

    </Grid>

</ContentPage>