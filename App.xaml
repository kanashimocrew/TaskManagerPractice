<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:TaskManager.Converters"
             x:Class="TaskManager.App">

    <Application.Resources>
        <ResourceDictionary>

            <Color x:Key="PrimaryColor">#512DA8</Color>
            <Color x:Key="PrimaryDarkColor">#311B92</Color>
            <Color x:Key="AccentColor">#FF4081</Color>
            <Color x:Key="Primary">#512DA8</Color>

            <Color x:Key="TextPrimary">#212121</Color>
            <Color x:Key="TextSecondary">#757575</Color>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:PriorityToColorConverter x:Key="PriorityToColor" />
            <converters:StatusToIconConverter x:Key="StatusToIcon" />
            <converters:DateTimeToStringConverter x:Key="DateTimeToString" />
            <converters:PriorityTextConverter x:Key="PriorityTextConverter" />
            <converters:StatusTextConverter x:Key="StatusTextConverter" />

        </ResourceDictionary>
    </Application.Resources>

</Application>